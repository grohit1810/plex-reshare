# Copy to .env and fill in PLEX_TOKEN. See README for details.

# starlette / gunicorn
WORKERS_PER_CORE=1
MAX_WORKERS=40
WEB_CONCURRENCY=10
GRACEFUL_TIMEOUT=120
TIMEOUT=130
PORT=8000

# redis
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_DB_RQ=12
REDIS_INTERNAL=true            # use the container's built-in redis

# plex
PLEX_TOKEN="xxxxxxxxxxxxxxxxxxxx"   # required: your X-Plex-Token

# content filters (applied while crawling)
IGNORE_PLAYLIST=""            # name of a playlist whose items to exclude (optional)
IGNORE_RESOLUTIONS="sd"       # comma list of resolutions to skip, e.g. "sd"
IGNORE_EXTENSIONS="avi"       # comma list of containers to skip, e.g. "avi"
MOVIE_MIN_SIZE=512            # skip movies smaller than this (MB)
EPISODE_MIN_SIZE=64           # skip episodes smaller than this (MB)
IGNORE_MOVIE_TEMPLATES=".*sample.*"   # pipe-separated regexes to skip by filename
IGNORE_EPISODE_TEMPLATES=""           # pipe-separated regexes to skip by path

# crawl / refresh tuning
PLEX_CONTAINER_SIZE=400       # items fetched per page (larger = fewer requests)
REFRESH_HOURS_MIN=5           # min gap before re-crawling a server
REFRESH_HOURS_MAX=12          # max gap (a random value in this range is used)
FULL_CRAWL_DAYS_MIN=6         # periodic from-scratch rebuild, randomized between
FULL_CRAWL_DAYS_MAX=9         # MIN and MAX days to avoid a fixed schedule
LAZY_DELETE_ON_404=true       # drop a listing entry if playback returns 404
SHOWS_PER_BATCH=-1            # split shows into batchNN/ folders of this size;
                             # <= 0 = no batching (flat). Existing shows never move.

# targeted plex scan (OFF by default): drip-scan new content into your OWN plex one
# folder at a time so friends' servers are never burst-scanned. Talks ONLY to
# PLEX_SCAN_URL; only libraries rooted under PLEX_SCAN_MOUNT_ROOT are in scope.
PLEX_SCAN_ENABLED=false
PLEX_SCAN_URL=http://PLEX_LOCAL_IP:PORT   # your reshare plex server, e.g. http://192.168.1.22:32400
PLEX_SCAN_MOUNT_ROOT=R:                   # survives a remount; only these libs scanned
PLEX_SCAN_INTERVAL_MIN=5                  # one folder per N minutes
PLEX_SCAN_WINDOW_START=07:30              # only scan between these local times
PLEX_SCAN_WINDOW_END=11:30
PLEX_SCAN_TZ=Europe/London
PLEX_SCAN_MAX_WAIT_MIN=30                 # cap wait for one folder's scan to finish
PLEX_SCAN_COOLDOWN_MIN=360                # don't re-request the same folder within this

# logging
LOG_LEVEL=INFO                # DEBUG for per-request tracing; INFO for summaries
# LOG_FILE=/pr/plex-reshare.log  # also write logs to this file (under /pr); off if unset
# LOG_FILE_MAX_MB=10             # rotate the log file at this size
# LOG_FILE_BACKUPS=3             # number of rotated files to keep

# optional
DEVELOPMENT=false
